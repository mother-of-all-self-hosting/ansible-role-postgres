#!/bin/bash

if [ $# -ne 1 ]; then
    echo "Usage: "$0" <directory_path>"
    echo "A latest-dump.sql.gz file will be dumped to the specified directory"
    exit 1
fi

directory_path=$1

if [ ! -d "$directory_path" ]; then
    echo "$directory_path does not exist."
    exit 1
fi

docker_flags=''
if [ -t 1 ]; then
    # Got tty
    docker_flags='-it'
fi

docker run \
    $docker_flags \
    --rm \
    --user={{ postgres_container_uid }}:{{ postgres_container_gid }} \
    --cap-drop=ALL \
    --env-file={{ postgres_base_path }}/env-postgres-psql \
    {% if postgres_cli_use_unix_socket_enabled %}
    --mount type=bind,src={{ postgres_run_path }},dst={{ postgres_run_path_in_container }} \
    {% else %}
    --network={{ postgres_container_network }} \
    {% endif %}
    --mount type=bind,src=$directory_path,dst=/out \
    --entrypoint={{ postgres_container_shell_path }} \
    {{ postgres_container_image_to_use }} \
    -c \
    'set -o pipefail && pg_dumpall -h {{ postgres_run_path_in_container if postgres_cli_use_unix_socket_enabled else postgres_connection_hostname }} | zstd --stdout > /out/latest-dump.sql.zst'
